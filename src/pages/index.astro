---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<?php

set_time_limit(60);

function normalizeUrl($url) {
    $url = trim($url);
    if (!preg_match("~^https?://~", $url)) {
        $url = "https://" . $url;
    }
    return rtrim($url, '/');
}

function getLinks($url, $domain) {
    $html = @file_get_contents($url);

    if (!$html) {
        return [];
    }

    preg_match_all('/href=["\'](.*?)["\']/i', $html, $matches);

    $links = [];

    foreach ($matches[1] as $link) {

        if (strpos($link, '#') === 0 ||
            strpos($link, 'mailto:') === 0 ||
            strpos($link, 'tel:') === 0) {
            continue;
        }

        if (strpos($link, 'http') !== 0) {
            $link = rtrim($domain, '/') . '/' . ltrim($link, '/');
        }

        $parsed = parse_url($link);

        if (!isset($parsed['host'])) {
            continue;
        }

        if ($parsed['host'] === parse_url($domain, PHP_URL_HOST)) {
            $links[] = strtok($link, '#');
        }
    }

    return array_unique($links);
}

$sitemap = "";
$error = "";

if (!empty($_POST['url'])) {

    $startUrl = normalizeUrl($_POST['url']);

    $visited = [];
    $toVisit = [$startUrl];
    $maxPages = 100;

    while (!empty($toVisit) && count($visited) < $maxPages) {

        $current = array_shift($toVisit);

        if (in_array($current, $visited)) {
            continue;
        }

        $visited[] = $current;

        $links = getLinks($current, $startUrl);

        foreach ($links as $link) {
            if (!in_array($link, $visited) &&
                !in_array($link, $toVisit)) {
                $toVisit[] = $link;
            }
        }
    }

    if (!empty($visited)) {

        $xml = new SimpleXMLElement(
            '<?xml version="1.0" encoding="UTF-8"?><urlset/>'
        );

        $xml->addAttribute(
            'xmlns',
            'http://www.sitemaps.org/schemas/sitemap/0.9'
        );

        foreach ($visited as $page) {
            $url = $xml->addChild('url');
            $url->addChild('loc', htmlspecialchars($page));
        }

        $sitemap = $xml->asXML();

    } else {
        $error = "Website konnte nicht gelesen werden.";
    }
}
?>



<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>👉 obst.party</h1>
			<h2>XML Sitemap Generator</h2>
		</main>
<form method="post">
    <input
        type="text"
        name="url"
        placeholder="https://example.com"
        required
    >
    <button type="submit">
        Create Sitemap
    </button>
</form>

<?php if($error): ?>
<p><?= htmlspecialchars($error) ?></p>
<?php endif; ?>

<?php if($sitemap): ?>

<h3>Completed Sitemap</h3>

<a href="data:text/xml;charset=utf-8,<?= urlencode($sitemap) ?>"
   download="sitemap.xml">
   Download Sitemap
</a>

<textarea readonly><?= htmlspecialchars($sitemap) ?></textarea>

<?php endif; ?>

</body>
</html>
